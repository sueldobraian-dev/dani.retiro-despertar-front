# ---------------------------------------------------------------------------
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO
# Copia este archivo con el nombre ".env.local" en tu directorio raíz 
# y completa los campos con los valores correspondientes a tu entorno.
# ---------------------------------------------------------------------------

# --- CONFIGURACIÓN DE SUPABASE (Base de datos y cliente) ---
# URL pública de tu API del proyecto en Supabase (Usada por el cliente y backend)
NEXT_PUBLIC_SUPABASE_URL=tu_supabase_url

# Llave pública anon de Supabase (Permite consultas públicas de lectura seguras)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# Token de Acceso Personal (PAT) de la Management API de Supabase 
# Se obtiene en la sección Cuenta de Supabase -> Access Tokens y sirve para auto-restaurar (despertar) la BD
SUPABASE_MANAGEMENT_PAT=tu_personal_access_token_aqui


# --- CONFIGURACIÓN DE CLOUDINARY (Gestión y obtención de galería) ---
# Nombre de la nube de tu cuenta de Cloudinary (Cloud Name)
CLOUDINARY_CLOUD_NAME=tu_cloudinary_cloud_name_aqui

# Clave API pública de tu cuenta de Cloudinary (API Key)
CLOUDINARY_CLIENT_ID=tu_cloudinary_api_key_aqui

# Clave secreta privada de tu cuenta de Cloudinary (API Secret) - MANTENER SECRETA
CLOUDINARY_CLIENT_SECRET=tu_cloudinary_api_secret_aqui


# --- CONFIGURACIONES DE UX & SOPORTE ---
# Define si se muestran descripciones detalladas de los fallos HTTP en el navegador (true/false)
NEXT_PUBLIC_SHOW_DETAILED_ERRORS=true

# Número de WhatsApp al cual redirigir las consultas del widget flotante (con código de país sin el signo +)
NEXT_PUBLIC_WHATSAPP_NUMBER=5492211111111
